<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="alohamini">
  <!--
    Gazebo Classic simulation with holonomic (omni/mecanum-style) motion via the
    libgazebo_ros_planar_move plugin.

    Unlike alohamini_base.gazebo.xacro (which drives the three wheel joints through
    ros2_control and cannot produce true sideways motion in Classic Gazebo because
    omni-wheel rollers are not modelled), this variant treats the base as a body that
    can slide freely in the plane. planar_move consumes /cmd_vel directly and moves
    the base, so forward / strafe / yaw all work immediately and match the real
    holonomic kinematics. Trade-off: this is a kinematic shortcut — the wheels do not
    generate the motion through contact (they are kept low-friction and spin only for
    visualisation). Same /cmd_vel, /odom and odom->base_footprint TF interface.

    Frame convention: the SolidWorks-exported base_link does NOT follow REP-103
    (its +X points left, +Y points backward). We add a REP-103 base_footprint root
    (x = forward, y = left) rotated +90 deg about Z relative to base_link, and drive
    that with planar_move, so cmd_vel linear.x = forward and linear.y = left as
    expected. If forward/back or left/right comes out reversed on your build, flip
    base_yaw_deg (try -90, 90, 180).
  -->

  <xacro:arg name="base_yaw_deg" default="90.0"/>

  <!-- Reuse the existing robot description (meshes, links, joints). -->
  <xacro:include filename="$(find alohamini_description)/urdf/alohamini_nav.urdf"/>

  <!-- REP-103 root frame. planar_move drives this; base_link (mesh) hangs off it,
       rotated so the mesh's real forward aligns with base_footprint +X. -->
  <link name="base_footprint"/>
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 ${radians($(arg base_yaw_deg))}"/>
  </joint>

  <!-- Holonomic planar drive: subscribes /cmd_vel, publishes /odom + TF. -->
  <gazebo>
    <plugin name="planar_move" filename="libgazebo_ros_planar_move.so">
      <ros>
        <namespace>/</namespace>
        <remapping>cmd_vel:=cmd_vel</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <update_rate>50</update_rate>
      <publish_rate>30</publish_rate>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <covariance_x>0.0001</covariance_x>
      <covariance_y>0.0001</covariance_y>
      <covariance_yaw>0.01</covariance_yaw>
    </plugin>
  </gazebo>

  <!-- Wheels: low friction so they do not fight the planar drive; visual spin only. -->
  <xacro:macro name="wheel_gazebo" params="link">
    <gazebo reference="${link}">
      <mu1>0.0</mu1>
      <mu2>0.0</mu2>
      <material>Gazebo/Black</material>
    </gazebo>
  </xacro:macro>
  <xacro:wheel_gazebo link="wheel1"/>
  <xacro:wheel_gazebo link="wheel2"/>
  <xacro:wheel_gazebo link="wheel3"/>

  <gazebo reference="base_link">
    <material>Gazebo/Grey</material>
  </gazebo>
</robot>
